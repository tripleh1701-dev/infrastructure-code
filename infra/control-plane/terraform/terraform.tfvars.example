project_name  = "license-portal"
environment   = "dev"
aws_region    = "us-east-1"

# Cognito
enable_mfa               = false
enable_advanced_security = false
cognito_callback_urls    = ["http://localhost:3000/callback"]
cognito_logout_urls      = ["http://localhost:3000"]
enable_cognito_auth      = true

# Lambda
lambda_runtime      = "nodejs20.x"
lambda_memory_size  = 512
lambda_timeout      = 30
lambda_package_path = "lambda-placeholder.zip"

# Data Plane (set after data-plane bootstrap)
data_plane_role_arn       = ""
data_plane_dynamodb_name  = ""
data_plane_region         = "us-east-1"
cross_account_external_id = "license-portal-xaccount-2026"

# Monitoring
alarm_email = ""

# ---- Credential Notification / SES ----
credential_notification_enabled = true
ses_sender_email                = "noreply@yourdomain.com"      # Must be SES-verified
platform_name                   = "Trumpet DevOps"
platform_support_email          = "support@yourdomain.com"
platform_login_url              = ""                            # Auto-derived from CloudFront if blank

# ---- Admin ----
admin_email                     = "admin@yourdomain.com"        # Cognito admin user for smoke test verification

# ---- GitHub Actions OIDC ----
enable_github_oidc   = true
create_oidc_provider = true                     # Set false if OIDC provider already exists in this AWS account
github_org           = "your-github-org"        # GitHub org or username
github_repo          = "license-portal"         # Repository name
tf_state_bucket      = "your-tf-state-bucket"   # S3 bucket for Terraform state
tf_lock_table        = "your-tf-lock-table"     # DynamoDB table for Terraform lock
